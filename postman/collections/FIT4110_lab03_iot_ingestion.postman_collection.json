{
  "info": {
    "_postman_id": "fit4110-lab03-iot-ingestion",
    "name": "FIT4110 Lab03 - IoT Ingestion Contract Tests",
    "description": "Provider-side and consumer-side contract tests for FIT4110 Lab 03. The same collection runs against mock and local environments without hardcoded baseUrl or authToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab03';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - service is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public health check used by Prism wait-on and local readiness checks."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Health response has required schema', function () {",
                  "  const schema = {",
                  "    type: 'object',",
                  "    required: ['status', 'service', 'version'],",
                  "    properties: {",
                  "      status: { type: 'string', enum: ['ok'] },",
                  "      service: { type: 'string' },",
                  "      version: { type: 'string' }",
                  "    }",
                  "  };",
                  "  pm.response.to.have.jsonSchema(schema);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /readings - happy path creates reading",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": ["{{baseUrl}}"],
              "path": ["readings"]
            },
            "description": "Payload mirrors mock-data/sensor-reading-valid.json.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has created reading schema', function () {",
                  "  const schema = {",
                  "    type: 'object',",
                  "    required: ['reading_id', 'device_id', 'metric', 'accepted', 'created_at'],",
                  "    properties: {",
                  "      reading_id: { type: 'string' },",
                  "      device_id: { type: 'string' },",
                  "      metric: { type: 'string', enum: ['temperature', 'humidity', 'motion', 'smoke'] },",
                  "      accepted: { type: 'boolean' },",
                  "      created_at: { type: 'string' }",
                  "    }",
                  "  };",
                  "  pm.response.to.have.jsonSchema(schema);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.device_id).to.eql('ESP32-LAB-A01');",
                  "  pm.expect(json.metric).to.eql('temperature');",
                  "  pm.expect(json.accepted).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /readings/latest - list latest readings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/latest?device_id=ESP32-LAB-A01&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["readings", "latest"],
              "query": [
                { "key": "device_id", "value": "ESP32-LAB-A01" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  if (json.items.length > 0) {",
                  "    pm.expect(json.items[0]).to.include.keys(['reading_id', 'device_id', 'metric', 'value', 'timestamp']);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /readings/latest - valid token is accepted",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/latest?limit=1",
              "host": ["{{baseUrl}}"],
              "path": ["readings", "latest"],
              "query": [
                { "key": "limit", "value": "1" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token request returns success', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /readings - missing token is rejected by local service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": ["{{baseUrl}}"],
              "path": ["readings"]
            },
            "description": "No Prefer: code=401 is used. This is a real auth assertion on local service; Prism mock records the limitation.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Mock limitation recorded: Prism does not enforce real bearer auth', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 401, 403]);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "  pm.test('Unauthorized response follows ProblemDetails', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.include.keys(['title', 'status', 'detail']);",
                  "    pm.expect(json.status).to.be.within(400, 599);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /readings - invalid token is rejected by local service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token" }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": ["{{baseUrl}}"],
              "path": ["readings"]
            },
            "description": "No Prefer: code=401 is used. Local service must reject the invalid token by auth logic.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Mock limitation recorded: invalid token needs real auth middleware', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 401, 403]);",
                  "  });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
